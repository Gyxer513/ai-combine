# ============================================================
# AI Combine — example environment variables
# Copy to .env and fill in. .env must have 600 permissions and must NOT be committed to git.
# ============================================================

# --- Alibaba Model Studio (international, Singapore) ---
# The Qwen family goes through dashscope-intl; third-party models (GLM/DeepSeek) go through the MaaS workspace.
ALIBABA_API_KEY=sk-...
# Note: for this account GLM-5.1 and DeepSeek are served via dashscope-intl
# (the same key as Qwen) — a separate MaaS workspace URL/ID is not needed.

# --- OpenRouter ---
OPENROUTER_API_KEY=sk-or-v1-...

# --- LiteLLM ---
# Single internal key that frontends/agents use to reach the proxy. Generate your own.
LITELLM_MASTER_KEY=sk-litellm-change-me

# --- Orchestrator authentication ---
# Bearer token for /chat, /agents, /v1/* — agents have access to the GitHub PAT / RAG /
# sandbox-broker, so without a token anyone who can reach the port could invoke an agent.
# Generate a random one (e.g. `openssl rand -hex 32`). Bots/workers use the same
# token from ORCHESTRATOR_API_TOKEN; in OpenWebUI set it as the connection's "API key".
# Empty = NOT enforced (relying only on localhost bind) — the orchestrator will warn.
ORCHESTRATOR_API_TOKEN=

# --- Telegram (Stage 5) ---
# One bot per agent (created via @BotFather). Only the configured ones are polled.
# TELEGRAM_BOT_TOKEN — shared, used by assistant (unless TELEGRAM_BOT_TOKEN_ASSISTANT is set).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_ASSISTANT=
TELEGRAM_BOT_TOKEN_RECON=
TELEGRAM_BOT_TOKEN_CODER=
TELEGRAM_BOT_TOKEN_PLANNER=
# Comma-separated whitelist of allowed user_id values (shared across all bots).
TELEGRAM_ALLOWED_USERS=
# An empty whitelist by default = NOBODY (fail-closed); denied ids are written to the log.
# true — allow everyone when the list is empty (local bootstrap only, NOT for production).
TELEGRAM_ALLOW_BOOTSTRAP=false

# --- Nextcloud (RAG indexer, Stage 3) ---
NEXTCLOUD_URL=https://nextcloud.example.com
NEXTCLOUD_USER=agent-reader
NEXTCLOUD_APP_PASSWORD=
# Notes categories -> namespace (unmapped -> personal). Comma-separated.
RAG_NOTES_CATEGORY_MAP=
# WebDAV folders -> namespace ("/Knowledge/Security:security, /Knowledge/Coding:coding").
RAG_WEBDAV_FOLDERS=

# --- Deck worker (autonomy): tasks from Nextcloud Deck ---
# Board names below must match your Nextcloud board names.
DECK_BOARD=AI Combine Tasks
# Card label -> agent. Create labels sec/code/ask on the board — planner attaches them
# to child tasks, and the deck worker routes the executor based on them.
DECK_LABEL_AGENT_MAP=sec:recon,code:coder,ask:assistant
DECK_POLL_INTERVAL_MIN=2
# Where a card moves on failure (NOT to Done). Create this stack on the board,
# otherwise a failed card stays in In Progress. Empty/no stack = it just hangs there.
DECK_FAILED_STACK=Failed

# --- Research worker (assistant: income research) ---
# Board name must match your Nextcloud board names.
RESEARCH_BOARD=Ideas
RESEARCH_STACK=New
RESEARCH_MODEL=qwen-flash
RESEARCH_IDEAS_PER_RUN=2
RESEARCH_INTERVAL_MIN=1440
# Themes to rotate through (CSV). Empty -> default from config.
RESEARCH_THEMES=

# --- Gitea (coder, Stage 6) ---
GITEA_URL=https://gitea.example.com
GITEA_TOKEN=

# --- GitHub (coder: repositories; bridge for the homelab) ---
# coder pushes to GitHub (the work GitLab is behind a VPN), GitHub<->GitLab sync is manual.
# PAT (fine-grained, scoped to the target repo: Contents RW + Pull requests RW).
GITHUB_TOKEN=
# Repository: "owner/name".
GITHUB_REPO=
GITHUB_DEFAULT_BRANCH=main

# --- Internal service addresses (defaults for the docker network) ---
LITELLM_BASE_URL=http://litellm:4000/v1
QDRANT_URL=http://qdrant:6333
SEARXNG_URL=http://searxng:8080
# Where the Telegram bot goes to fetch agent responses.
ORCHESTRATOR_URL=http://orchestrator:8000
