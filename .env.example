# ============================================================
# AI Combine — пример переменных окружения
# Скопируй в .env и заполни. .env должен иметь права 600 и НЕ попадать в git.
# ============================================================

# --- Alibaba Model Studio (международная, Singapore) ---
# Qwen-семейство ходит через dashscope-intl, сторонние модели (GLM/DeepSeek) — через MaaS workspace.
ALIBABA_API_KEY=sk-...
# Примечание: GLM-5.1 и DeepSeek для этого аккаунта раздаются через dashscope-intl
# (тот же ключ, что Qwen) — отдельный MaaS-workspace URL/ID не нужен.

# --- OpenRouter ---
OPENROUTER_API_KEY=sk-or-v1-...

# --- LiteLLM ---
# Единый внутренний ключ, которым фронтенды/агенты ходят в прокси. Сгенерируй сам.
LITELLM_MASTER_KEY=sk-litellm-change-me

# --- Telegram (Этап 5) ---
# Один бот на агента (создаются в @BotFather). Поллятся только заданные.
# TELEGRAM_BOT_TOKEN — общий, идёт Колобку (если не задан TELEGRAM_BOT_TOKEN_KOLOBOK).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_KOLOBOK=
TELEGRAM_BOT_TOKEN_KOSCHEI=
TELEGRAM_BOT_TOKEN_LEVSHA=
TELEGRAM_BOT_TOKEN_DED=
# Whitelist разрешённых user_id через запятую (общий для всех ботов)
TELEGRAM_ALLOWED_USERS=
# Пустой whitelist по умолчанию = НИКОГО (fail-closed); id отказанных пишутся в лог.
# true — пускать всех при пустом списке (только для локального bootstrap, НЕ для прода).
TELEGRAM_ALLOW_BOOTSTRAP=false

# --- Nextcloud (RAG-индексатор, Этап 3) ---
NEXTCLOUD_URL=https://nextcloud.example.com
NEXTCLOUD_USER=agent-reader
NEXTCLOUD_APP_PASSWORD=
# Категории Notes -> namespace (несопоставленные -> personal). Через запятую.
RAG_NOTES_CATEGORY_MAP=
# Папки WebDAV -> namespace ("/Knowledge/Security:security, /Knowledge/Coding:coding").
RAG_WEBDAV_FOLDERS=

# --- Deck-worker (автономия): задачи из Nextcloud Deck ---
DECK_BOARD=Задачи AI Combine
DECK_LABEL_AGENT_MAP=sec:koschei,code:levsha,ask:kolobok
DECK_POLL_INTERVAL_MIN=2

# --- Research-worker (Колобок: ресёрч заработка) ---
RESEARCH_BOARD=Идеи
RESEARCH_STACK=Новые
RESEARCH_MODEL=qwen-flash
RESEARCH_IDEAS_PER_RUN=2
RESEARCH_INTERVAL_MIN=1440
# Темы для ротации (CSV). Пусто -> дефолт из config.
RESEARCH_THEMES=

# --- Gitea (Левша, Этап 6) ---
GITEA_URL=https://gitea.example.com
GITEA_TOKEN=

# --- GitHub (Левша: репозитории; перемычка для хоумлаба) ---
# Левша пушит в GitHub (рабочий GitLab за VPN), синхронизация GitHub<->GitLab вручную.
# PAT (fine-grained, scope на нужный репо: Contents RW + Pull requests RW).
GITHUB_TOKEN=
# Репозиторий: "owner/name".
GITHUB_REPO=
GITHUB_DEFAULT_BRANCH=main

# --- Внутренние адреса сервисов (дефолты для docker-сети) ---
LITELLM_BASE_URL=http://litellm:4000/v1
QDRANT_URL=http://qdrant:6333
SEARXNG_URL=http://searxng:8080
# Куда Telegram-бот ходит за ответами агентов.
ORCHESTRATOR_URL=http://orchestrator:8000
